<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/app_name"
                android:scaleType="centerCrop"
                android:src="@drawable/brand_icon" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SafeBus Driver"
                android:textColor="@color/text_main"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/refreshDriverButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Refresh" />

            <Button
                android:id="@+id/logoutDriverButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="Logout" />
        </LinearLayout>

        <EditText
            android:id="@+id/stopNameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/input_background"
            android:hint="Stop name for near-stop alert"
            android:inputType="textCapWords" />

        <Button
            android:id="@+id/nearStopButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="Send Near Stop Alert" />

        <TextView
            android:id="@+id/driverStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_background"
            android:text="Ready"
            android:textColor="@color/text_main"
            android:textSize="15sp" />

        <Button
            android:id="@+id/startRouteButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:text="Start Route" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/departureButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Departure" />

            <Button
                android:id="@+id/delayButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Delay" />

            <Button
                android:id="@+id/arrivalButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Arrival" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Location Sender"
            android:textColor="@color/text_main"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/latInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:hint="Latitude"
            android:inputType="numberDecimal|numberSigned" />

        <EditText
            android:id="@+id/lngInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:hint="Longitude"
            android:inputType="numberDecimal|numberSigned" />

        <Button
            android:id="@+id/sendLocationButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="Send GPS" />

        <Button
            android:id="@+id/sendCurrentLocationButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="Send Current Phone GPS" />

        <Button
            android:id="@+id/openDriverMapButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="Open Bus Map" />

        <TextView
            android:id="@+id/driverLiveText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Auto-refresh every 15 seconds"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/driverNotificationsList"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginTop="14dp" />
    </LinearLayout>
</ScrollView>
