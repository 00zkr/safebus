<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/brand_icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SafeBus Parent"
            android:textColor="@color/text_main"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/refreshParentButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Refresh" />

        <Button
            android:id="@+id/logoutParentButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="Logout" />
    </LinearLayout>

    <TextView
        android:id="@+id/childInfoText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/card_background"
        android:textColor="@color/text_main"
        android:textSize="15sp" />

    <Button
        android:id="@+id/openBusMapButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:text="Open Bus Map" />

    <TextView
        android:id="@+id/parentLiveText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Auto-refresh every 15 seconds"
        android:textColor="@color/muted"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Spinner
            android:id="@+id/typeFilter"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1" />

        <EditText
            android:id="@+id/dateFilter"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/input_background"
            android:hint="YYYY-MM-DD"
            android:inputType="date" />

        <Button
            android:id="@+id/filterButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="Filter" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/notificationsList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1" />
</LinearLayout>
